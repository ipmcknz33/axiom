# =============================================================================
# Axiom — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# .env is gitignored. Never commit real keys.
#
# Legend:
#   [REQUIRED NOW]    — app will not start without this
#   [OPTIONAL]        — safe to omit; feature degrades gracefully
#   [SERVER ONLY]     — never expose to the browser; Next.js NEXT_PUBLIC_ prefix
#                       controls client vs server visibility
#   [PUBLIC]          — safe to expose to the browser (NEXT_PUBLIC_ prefix)
# =============================================================================

# -----------------------------------------------------------------------------
# App environment
# [OPTIONAL] [PUBLIC]
# Values: development | staging | production
# Defaults to "development" if omitted.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_ENV=development

# -----------------------------------------------------------------------------
# Site URL
# [OPTIONAL] [PUBLIC]
# Used for OAuth redirect URIs and absolute URL generation.
# Set to your deployed URL in staging/production.
# Retrieve: your hosting provider (Vercel, Railway, etc.)
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# =============================================================================
# Supabase
# Retrieve from: https://app.supabase.com -> project -> Settings -> API
# =============================================================================

# [REQUIRED NOW] [PUBLIC]
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# [REQUIRED NOW] [PUBLIC]
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# [REQUIRED NOW] [SERVER ONLY]
# Used for server-side Supabase operations (auth verification, DB writes).
# Never prefix with NEXT_PUBLIC_. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# =============================================================================
# Database
# Retrieve from: https://app.supabase.com -> project -> Settings -> Database
# =============================================================================

# [REQUIRED NOW] [SERVER ONLY]
# Direct Postgres connection string. Used for migrations and direct queries.
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# =============================================================================
# OpenAI
# [OPTIONAL — REQUIRED for live LLM phase] [SERVER ONLY]
# Without this key the orchestrator runs in stub/deterministic mode.
# Retrieve from: https://platform.openai.com/api-keys
# =============================================================================

# OPENAI_API_KEY=sk-proj-...

# Chat completion model. Defaults to gpt-4o-mini when omitted.
# OPENAI_MODEL=gpt-4o-mini

# Embedding model for ingestion + query vectors. Defaults to text-embedding-3-small.
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# =============================================================================
# LangSmith — run tracing and observability
# [OPTIONAL] [SERVER ONLY]
# Tracing is inactive unless BOTH LANGSMITH_API_KEY and LANGSMITH_TRACING=true
# are set. Safe to omit entirely in development.
# Retrieve from: https://smith.langchain.com -> Settings -> API Keys
# =============================================================================

# LANGSMITH_API_KEY=lsv2_pt_...

# Set to "true" (or "1", "on", "yes") to enable trace upload to LangSmith.
# LANGSMITH_TRACING=true

# Project to group runs under. Defaults to "axiom-dev".
# LANGSMITH_PROJECT=axiom-dev

# LangSmith ingestion endpoint. Only needed for self-hosted LangSmith.
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
